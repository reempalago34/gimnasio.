# ==========================================
# CONFIGURACIÓN DE BASE DE DATOS POSTGRESQL
# ==========================================
# Formato de DATABASE_URL: postgresql://username:password@host:port/database
# Ejemplo: postgresql://gimnasio_user:password123@db.example.com:5432/gimnasio_db
DATABASE_URL=postgresql://user:password@localhost:5432/gimnasio_db

# Credenciales de PostgreSQL (Solo para docker-compose local)
POSTGRES_USER=gimnasio_user
POSTGRES_PASSWORD=tu_contrasena_segura_aqui
POSTGRES_DB=gimnasio_db

# ==========================================
# CONFIGURACIÓN DE LA APLICACIÓN FLASK
# ==========================================
FLASK_ENV=production
SECRET_KEY=cambia-esto-por-una-clave-segura-en-produccion

# ==========================================
# CREDENCIALES DEL ADMINISTRADOR INICIAL
# ==========================================
# Se crean automáticamente en el primer despliegue
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=tu_contrasena_segura_aqui

# ==========================================
# CONFIGURACIÓN DEL PUERTO (Opcional)
# ==========================================
# Por defecto es 81, puedes cambiarlo si lo necesitas
PORT=81
