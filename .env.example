# Configuración de la Base de Datos
DATABASE_URL=sqlite:///instance/flaskdb.sqlite

# Configuración de Postgres (Solo si usas Docker con Postgres)
POSTGRES_USER=flask_user
POSTGRES_PASSWORD=flask_password
POSTGRES_DB=flask_db

# Seguridad
SECRET_KEY=cambiame-por-una-clave-segura-en-produccion

# Credenciales del Administrador por Defecto (Semilla)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=tu_contrasena_segura_aqui
