# ==========================================
# CONFIGURACIÓN DE BASE DE DATOS POSTGRESQL
# ==========================================
# Para docker-compose local:
# DATABASE_URL=postgresql://Erickgimnasio2026:tu_password@db:5432/gimnasio_db
#
# Para Coolify (apunta a tu PostgreSQL externo):
# DATABASE_URL=postgresql://usuario:password@host.ejemplo.com:5432/base_datos
#
# IMPORTANTE: Asegúrate de que el host sea accesible desde Docker/Coolify
DATABASE_URL=postgresql://Erickgimnasio2026:mi_password_seguro@db:5432/gimnasio_db

# Credenciales de PostgreSQL (si usas docker-compose local)
POSTGRES_USER=Erickgimnasio2026
POSTGRES_PASSWORD=mi_password_seguro
POSTGRES_DB=gimnasio_db

# ==========================================
# CONFIGURACIÓN DE LA APLICACIÓN FLASK
# ==========================================
FLASK_ENV=production
SECRET_KEY=cambia-esto-por-una-clave-super-segura-en-produccion

# ==========================================
# CREDENCIALES DEL ADMINISTRADOR INICIAL
# ==========================================
# Se crean automáticamente en el primer acceso a la aplicación
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# ==========================================
# CONFIGURACIÓN DEL PUERTO (Opcional)
# ==========================================
# Por defecto es 81
PORT=81
